    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
}

        .hero-job { font-size: calc(3.5rem * var(--scale)); font-weight: 900; letter-spacing: 15px; margin: 100px 0 150px 0; text-align: center; }

        /* --- CONSTRAINED BRANCHING SECTIONS --- */
        .branch-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
            position: relative;
            margin-bottom: 100px;
        }

        .center-line {
            width: 6px;
            background: var(--purple);
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            top: 50px; 
            bottom: 40px; 
            z-index: -1;
        }

        .side { width: 100%; position: relative; padding: 60px 0; }
        
        .about-side { text-align: right; padding-right: calc(50% + 40px); }
        .about-branch { 
            position: absolute; 
            right: 50%; 
            top: 50px; 
            width: 120px; 
            height: 6px; 
            background: var(--purple); 
        }
        .about-bottom-line { 
            position: absolute; 
            right: 50%; 
            bottom: 40px; 
            width: 80px; 
            height: 6px; 
            background: var(--purple); 
