            text-transform: uppercase;
            margin-bottom: 25px;
            margin-top: 10px;
            scroll-margin-top: 50px; 
        }

        .about-text-container {
            max-width: 550px;
            margin-left: auto;
            line-height: 1.8;
            font-size: calc(1.05rem * var(--scale));
        }

        .skills-content {
            font-size: calc(1rem * var(--scale));
            line-height: 2;
        }

        /* --- PROJECTS & HOVER --- */
