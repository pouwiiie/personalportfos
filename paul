        .project-center { padding:  40px; position: center; }
        .project-title { font-size: 40px; font-weight: bold; text-transform: uppercase; }

      

        
       .projects-frame { 
        position: relative; 
        width: 100%; 
        padding: 60px 40px; 
        border: 4px solid var(--purple); 
    }
        .project-row { display: flex; justify-content: center; flex-wrap: wrap; gap: 30px; }

        .box {
    width: 160px;
    height: 160px;
    background-color: var(--project-brown);
    
    /* Background Image Centering */
    background-size: cover;
    background-position: center; 
    background-repeat: no-repeat;
    
    position: relative;
    overflow: hidden;
    border: 1px solid var(--purple);
    
    /* Blueprint shadow effect */
    box-shadow: 6px 6px 0px rgba(128, 0, 128, 0.3);
    transition: all 0.3s ease;
    margin-bottom: 12px; /* Space between the image and the title below */
    cursor: pointer;
}

.box-content {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(128, 0, 128, 0.9); /* Purple tint on hover */
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 15px;
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease;
}

       .box:hover {
    transform: translate(-3px, -3px);
    box-shadow: 10px 10px 0px var(--purple);
}

.box:hover .box-content {
    opacity: 1;
}

.project-item {
    display: flex;
    flex-direction: column;
    align-items: center; /* Centers the text labels under the image */
    width: 180px;
}
.box-title {
    font-size: 0.9rem;
    font-weight: bold;
    color: var(--bright-purple);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 4px;
    text-align: center;
    display: block; /* Ensures it takes its own line */
}

.box-title {
    transition: all 0.3s ease;
}

.box-desc {
    font-size: 0.65rem;
    color: #888;
    text-align: center;
    border-top: 1px solid rgba(128, 0, 128, 0.2);
    padding-top: 4px;
    width: 80%;
    display: block;
}

